# ── Supabase ──────────────────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_KEY=your-service-role-key

# ── TrueLayer ─────────────────────────────────────────────────
# Use sandbox credentials for dev, live credentials for prod
TRUELAYER_CLIENT_ID=your-truelayer-client-id
TRUELAYER_CLIENT_SECRET=your-truelayer-client-secret
# Dev:  http://localhost:3001/api/v1/banks/callback
# Prod: https://RAILWAY_URL/api/v1/banks/callback
TRUELAYER_REDIRECT_URI=http://localhost:3001/api/v1/banks/callback

# ── Encryption (generate with: openssl rand -hex 32) ─────────
ENCRYPTION_KEY=your-64-char-hex-encryption-key

# ── App ───────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development
# Dev:  http://localhost:5173
# Prod: https://app.vpayit.co.uk
FRONTEND_URL=http://localhost:5173
